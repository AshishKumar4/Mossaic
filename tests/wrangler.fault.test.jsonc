{
  "name": "mossaic-fault-tests",
  "main": "./test-worker.ts",
  "compatibility_date": "2025-09-06",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "name": "MOSSAIC_USER", "class_name": "FaultInjectingUserDO" },
      { "name": "MOSSAIC_SHARD", "class_name": "FaultInjectingShardDO" },
      { "name": "SEARCH_DO", "class_name": "SearchDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["FaultInjectingUserDO", "FaultInjectingShardDO", "SearchDO"] }
  ],
  "vars": {
    "JWT_SECRET": "test-secret-for-vitest-only"
  }
}
