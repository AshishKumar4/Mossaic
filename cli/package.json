{
	"name": "@mossaic/cli",
	"version": "0.1.0",
	"description": "Command-line interface for Mossaic VFS over @mossaic/sdk's HTTP fallback. Mints VFS tokens locally and speaks to a deployed Mossaic Service worker.",
	"type": "module",
	"main": "./dist/main.js",
	"types": "./dist/main.d.ts",
	"bin": {
		"mossaic": "./dist/bin.js",
		"mscli": "./dist/bin.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "concurrently --kill-others-on-fail -n cli,browser -c auto 'tsc --noEmit' 'tsc --noEmit -p tests/e2e/browser'",
		"test": "vitest run tests/unit",
		"test:e2e": "pnpm -w -F @mossaic/sdk build && pnpm -F @mossaic/cli build && vitest run tests/e2e --reporter=verbose",
		"test:e2e:browser": "playwright test"
	},
	"dependencies": {
		"@mossaic/sdk": "workspace:*",
		"commander": "^15.0.0",
		"jose": "^6.2.3",
		"ulid": "^3.0.2",
		"ws": "^8.21.0",
		"y-protocols": "^1.0.7",
		"yjs": "13.6.31"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"@types/ws": "^8.18.1",
		"concurrently": "^10.0.3",
		"execa": "^9.6.1",
		"tsdown": "^0.22.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20"
	},
	"license": "MIT"
}
