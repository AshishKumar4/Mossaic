{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": false,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src", "../shared", "../worker"]
}
